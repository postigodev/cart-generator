                  "const data = pm.response.json();",
                  "pm.test('cart draft id exists', function () {",
                  "  pm.expect(data.cart_draft_id).to.be.a('string');",
                  "});",
                  "pm.test('matched items array exists', function () {",
                  "  pm.expect(Array.isArray(data.matched_items)).to.eql(true);",
                  "});",
                  "",
                  "pm.collectionVariables.set('cartDraftId', data.cart_draft_id);"
