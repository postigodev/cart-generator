  "item": [
    {
      "name": "Recipes",
      "item": [
        {
          "name": "List Recipes",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('response is an array', function () {",
                  "  pm.expect(Array.isArray(data)).to.eql(true);",
                  "});",
                  "",
                  "if (Array.isArray(data) && data.length > 0 && data[0].id) {",
                  "  pm.collectionVariables.set('recipeId', data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{userId}}"
              },
              {
                "key": "x-request-id",
                "value": "{{requestId}}-list-recipes"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/recipes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "recipes"
              ]
            }
          }
        },
        {
          "name": "Create Recipe",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201 or 200', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('created recipe has id', function () {",
                  "  pm.expect(data.id).to.be.a('string');",
                  "});",
                  "",
                  "pm.collectionVariables.set('recipeId', data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-user-id",
                "value": "{{userId}}"
              },
              {
                "key": "x-request-id",
                "value": "{{requestId}}-create-recipe"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tallarines verdes caseros\",\n  \"cuisine\": \"Peruvian\",\n  \"description\": \"Pasta with herb sauce\",\n  \"servings\": 4,\n  \"ingredients\": [\n    {\n      \"canonical_ingredient\": \"pasta\",\n      \"amount\": 500,\n      \"unit\": \"g\"\n    },\n    {\n      \"canonical_ingredient\": \"cilantro\",\n      \"amount\": 2,\n      \"unit\": \"cup\"\n    }\n  ],\n  \"steps\": [\n    {\n      \"step\": 1,\n      \"what_to_do\": \"Boil the pasta.\"\n    },\n    {\n      \"step\": 2,\n      \"what_to_do\": \"Blend the herb sauce and combine.\"\n    }\n  ],\n  \"tags\": [\"dinner\", \"pasta\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/recipes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "recipes"
              ]
            }
          }
        },
        {
          "name": "Update Recipe",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const data = pm.response.json();",
                  "pm.test('recipe name updated', function () {",
                  "  pm.expect(data.name).to.eql('Tallarines verdes familiares');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-user-id",
                "value": "{{userId}}"
              },
              {
                "key": "x-request-id",
                "value": "{{requestId}}-update-recipe"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tallarines verdes familiares\",\n  \"description\": \"Updated family version for manual testing.\",\n  \"tags\": [\"dinner\", \"pasta\", \"updated\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/recipes/{{recipeId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "recipes",
                "{{recipeId}}"
              ]
            }
          }
        }
      ]
    },
